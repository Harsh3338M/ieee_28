// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string

  url = env("DATABASE_URL")
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String   // The catchy headline (e.g., "Beware of this WhatsApp Scam")
  content   String   @db.Text // The full story
  scamType  ScamType @default(GENERAL) // Categorization
  
  // Visual Evidence
  imageUrl  String?  // Screenshots of the scammer's messages
  
  // Statistics
  viewCount Int      @default(0)
  
  // Social/Reddit Features
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  

  @@index([title])
}

enum ScamType {
  PHISHING
  CRYPTO
  WHATSAPP
  MARKETPLACE
  JOB_OFFER
  GENERAL
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  profile       Profile?
  following     User[]    @relation("UserFollows")
  followedBy    User[]    @relation("UserFollows")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id                     String   @id @default(cuid())
  bio                    String?
  badges                 String[]
  xp                     Int      @default(0)
  points                 Int      @default(0)
  total_lesson_completed Int      @default(0)
  ai_lesson_completed    Int      @default(0)

  // 3. Reference to User ID
  userId    String   @unique
  user_name String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  streak    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
